{
	"compilerOptions": {
		"target": "ES2020",
		"lib": ["ES2020"],
		"rootDir": "src",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"paths": {
			"#lib/*": ["./src/*"]
		},
		"resolveJsonModule": true,
		"types": ["node"],
		"strict": true,
		"noImplicitOverride": true,
		"noImplicitThis": true,
		"noUnusedLocals": true,
		"declaration": true,
		"declarationDir": "dist",
		"downlevelIteration": true,
		"outDir": "dist",
		"sourceMap": false,
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true
	},
	"include": ["src"],
	"exclude": ["**/test", "node_modules", "dist"]
}
