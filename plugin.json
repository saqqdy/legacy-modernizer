{
  "name": "legacy-modernizer",
  "version": "0.1.1",
  "description": "Legacy Modernizer — 遗留代码现代化，扫描项目中的遗留模式（Vue 2、JS、Webpack），生成迁移报告并提供 AI 语义级迁移建议",
  "author": "saqqdy",
  "repository": "https://github.com/saqqdy/legacy-modernizer",
  "license": "MIT",
  "keywords": [
    "vue",
    "typescript",
    "migration",
    "modernization",
    "legacy-code",
    "vite",
    "webpack"
  ],
  "categories": ["development", "code-quality"],
  "commands": [
    {
      "name": "analyze",
      "description": "扫描项目目录，识别所有遗留模式，生成结构化迁移报告",
      "skill": "legacy-modernizer/analyze"
    },
    {
      "name": "modernize",
      "description": "交互式迁移向导：扫描 → 选择维度 → 生成计划 → 逐步迁移",
      "skill": "legacy-modernizer/modernize"
    }
  ],
  "skills": [
    {
      "name": "legacy-modernizer",
      "path": "legacy-modernizer/skill.md"
    },
    {
      "name": "legacy-modernizer/analyze",
      "path": "legacy-modernizer/analyze.md"
    },
    {
      "name": "legacy-modernizer/modernize",
      "path": "legacy-modernizer/modernize.md"
    }
  ],
  "compatibility": {
    "claudeCode": ">=0.1.0"
  }
}